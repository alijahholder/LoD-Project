# --- Core ---
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-me-with-openssl-rand-base64-32
DATABASE_URL="file:./dev.db"

# --- PHI Encryption (32-byte base64 key for envelope encryption) ---
PHI_ENCRYPTION_KEY=replace-me-with-openssl-rand-base64-32

# --- Storage (local in dev; S3 in prod) ---
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=./.uploads
# AWS_S3_BUCKET=
# AWS_S3_REGION=us-east-1
# AWS_KMS_KEY_ID=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- AI providers (mock in dev) ---
AI_DRIVER=mock
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# AWS_TEXTRACT_REGION=us-east-1

# --- Email / SMS (console in dev) ---
EMAIL_DRIVER=console
SMS_DRIVER=console
# POSTMARK_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=

# --- E-sign (mock in dev) ---
ESIGN_DRIVER=mock
# DOCUSIGN_INTEGRATION_KEY=
# DOCUSIGN_USER_ID=
# DOCUSIGN_ACCOUNT_ID=
# DOCUSIGN_PRIVATE_KEY=

# --- App settings ---
SESSION_IDLE_MINUTES=15
